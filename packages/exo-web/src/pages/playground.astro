let pendingAssistantMsgId: string | null = null;

/* ---- Message hover menu ---- */
function createMessageActions(
  messageEl: HTMLElement,
  role: "user" | "assistant",
  getText: () => string,
): HTMLElement {
  const menu = document.createElement("div");
  menu.className = "msg-actions absolute -top-8 right-0 flex items-center gap-0.5 px-1 py-0.5 rounded-lg bg-paper border border-dark/[0.08] shadow-sm opacity-0 group-hover:opacity-100 transition-opacity z-10";

  function makeBtn(icon: string, title: string, handler: () => void): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.className = "p-1 rounded text-muted hover:text-dark hover:bg-subtle transition-colors";
    btn.title = title;
    btn.innerHTML = icon;
    btn.addEventListener("click", handler);
    return btn;
  }

  /* Copy */
  const copyBtn = makeBtn(COPY_ICON, "Copy", function() {
    navigator.clipboard.writeText(getText()).then(function() {
      copyBtn.innerHTML = CHECK_ICON;
      copyBtn.classList.add("text-zen-green");
      setTimeout(function() {
        copyBtn.innerHTML = COPY_ICON;
        copyBtn.classList.remove("text-zen-green");
      }, 1500);
    });
  });
  menu.appendChild(copyBtn);

  /* Edit (user messages only) */
  if (role === "user") {
    menu.appendChild(makeBtn(EDIT_ICON, "Edit message", function() {
      startInlineEdit(messageEl);
    }));
  }

  /* Edit history (show on hover if edits exist) */
  if (role === "user") {
    const historyBtn = makeBtn(HISTORY_ICON, "Edit history", function() {
      showEditHistory(messageEl);
    });
    historyBtn.classList.add("edit-history-btn", "hidden");
    menu.appendChild(historyBtn);
  }

  /* Replay from here (user messages only) */
  if (role === "user") {
    menu.appendChild(makeBtn(REPLAY_ICON, "Replay from here", function() {
      replayFromMessage(messageEl);
    }));
  }

  /* Delete */
  menu.appendChild(makeBtn(DELETE_ICON, "Delete message", function() {
    deleteMessage(messageEl);
  }));

  return menu;
}

/* ---- Inline edit ---- */
function startInlineEdit(messageEl: HTMLElement) {
  const contentEl = messageEl.querySelector(".msg-content") as HTMLElement | null;
  if (!contentEl || messageEl.querySelector(".inline-editor")) return;

  const original = contentEl.textContent || "";
  contentEl.classList.add("hidden");

  const editor = document.createElement("div");
  editor.className = "inline-editor flex flex-col gap-2 w-full";

  const textarea = document.createElement("textarea");
  textarea.className = "w-full px-3 py-2 text-sm border border-dark/[0.08] rounded-lg bg-paper text-dark focus:outline-none focus:ring-2 focus:ring-coral/20 focus:border-coral resize-none";
  textarea.value = original;
  textarea.rows = Math.max(2, original.split("\n").length);

  const btnRow = document.createElement("div");
  btnRow.className = "flex items-center gap-2 justify-end";

  const cancelBtn = document.createElement("button");
  cancelBtn.className = "px-3 py-1 text-xs text-muted hover:text-dark rounded-lg hover:bg-subtle transition-colors";
  cancelBtn.textContent = "Cancel";
  cancelBtn.addEventListener("click", function() {
    editor.remove();
    contentEl.classList.remove("hidden");
  });

  const saveBtn = document.createElement("button");
  saveBtn.className = "px-3 py-1 text-xs font-medium bg-coral text-white rounded-lg hover:bg-coral/90 transition-colors";
  saveBtn.textContent = "Save";
  saveBtn.addEventListener("click", function() {
    const newContent = textarea.value.trim();
    if (!newContent) return;
    saveMessageEdit(messageEl, newContent).then(function() {
      contentEl.textContent = newContent;
      contentEl.classList.remove("hidden");
      editor.remove();
      /* Show the edit history button */
      const histBtn = messageEl.closest(".group")?.querySelector(".edit-history-btn");
      if (histBtn) histBtn.classList.remove("hidden");
    });
  });

  const replayBtn = document.createElement("button");
  replayBtn.className = "px-3 py-1 text-xs font-medium bg-zen-blue text-white rounded-lg hover:bg-zen-blue/90 transition-colors";
  replayBtn.textContent = "Save & Replay";
  replayBtn.addEventListener("click", function() {
    const newContent = textarea.value.trim();
    if (!newContent) return;
    saveMessageEdit(messageEl, newContent).then(function() {
      contentEl.textContent = newContent;
      contentEl.classList.remove("hidden");
      editor.remove();
      replayFromMessage(messageEl);
    });
  });

  btnRow.appendChild(cancelBtn);
  btnRow.appendChild(saveBtn);
  btnRow.appendChild(replayBtn);
  editor.appendChild(textarea);
  editor.appendChild(btnRow);

  contentEl.parentElement!.insertBefore(editor, contentEl.nextSibling);
  textarea.focus();
  textarea.setSelectionRange(textarea.value.length, textarea.value.length);
}

/* ---- Save edit via API ---- */
async function saveMessageEdit(messageEl: HTMLElement, newContent: string) {
  const msgId = messageEl.dataset.messageId;
  if (!msgId || !currentConversationId) return;

  const resp = await fetch(
    "/api/v1/conversations/" + currentConversationId + "/messages/" + msgId,
    {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ content: newContent }),
    }
  );
  if (!resp.ok) {
    appendError("Failed to save edit");
  }
}

/* ---- Show edit history tooltip ---- */
async function showEditHistory(messageEl: HTMLElement) {
  const msgId = messageEl.dataset.messageId;
  if (!msgId || !currentConversationId) return;

  const resp = await fetch(
    "/api/v1/conversations/" + currentConversationId + "/messages/" + msgId + "/edits"
  );
  if (!resp.ok) return;
  const edits: Array<{ original_content: string; edited_at: string }> = await resp.json();
  if (edits.length === 0) {
    appendError("No edit history");
    return;
  }

  /* Show a simple tooltip with past versions */
  const existing = messageEl.querySelector(".edit-history-tooltip");
  if (existing) { existing.remove(); return; }

  const tooltip = document.createElement("div");
  tooltip.className = "edit-history-tooltip absolute top-full left-0 mt-1 w-72 max-h-48 overflow-y-auto bg-paper border border-dark/[0.08] rounded-lg shadow-lg z-20 p-3";
  tooltip.innerHTML = '<div class="text-xs font-medium text-dark mb-2">Edit History</div>';
  edits.forEach(function(e) {
    const row = document.createElement("div");
    row.className = "text-xs text-muted mb-2 pb-2 border-b border-dark/[0.04] last:border-0 last:mb-0 last:pb-0";
    row.innerHTML = '<div class="text-[10px] text-muted/60 mb-0.5">' + e.edited_at + '</div><div class="whitespace-pre-wrap break-words">' + escapeHtml(e.original_content) + '</div>';
    tooltip.appendChild(row);
  });

  /* Close on click outside */
  function close(ev: MouseEvent) {
    if (!tooltip.contains(ev.target as Node)) {
      tooltip.remove();
      document.removeEventListener("click", close);
    }
  }
  setTimeout(function() { document.addEventListener("click", close); }, 0);

  messageEl.style.position = "relative";
  messageEl.appendChild(tooltip);
}

/* ---- Delete message via API ---- */
async function deleteMessage(messageEl: HTMLElement) {
  const msgId = messageEl.dataset.messageId;
  if (!msgId || !currentConversationId) return;

  if (!confirm("Delete this message?")) return;

  const resp = await fetch(
    "/api/v1/conversations/" + currentConversationId + "/messages/" + msgId,
    { method: "DELETE" }
  );
  if (!resp.ok) {
    appendError("Failed to delete message");
    return;
  }

  /* Remove from DOM — find the row (flex justify-start/end) */
  const row = messageEl.closest(".flex.justify-start, .flex.justify-end");
  if (row) row.remove();
}

/* ---- Replay from here ---- */
async function replayFromMessage(messageEl: HTMLElement) {
  const msgId = messageEl.dataset.messageId;
  if (!msgId || !currentConversationId || !ws || ws.readyState !== WebSocket.OPEN) return;

  const contentEl = messageEl.querySelector(".msg-content") as HTMLElement | null;
  const messageText = contentEl?.textContent || "";
  if (!messageText) return;

  /* Call replay API — truncates messages after this one */
  const resp = await fetch(
    "/api/v1/conversations/" + currentConversationId + "/messages/" + msgId + "/replay",
    { method: "POST" }
  );
  if (!resp.ok) {
    appendError("Failed to replay");
    return;
  }

  /* Clear chat and reconnect to reload truncated conversation, then re-send */
  const agentId = currentAgentId;
  const convId = currentConversationId;
  if (!agentId) return;

  /* Clear UI */
  const children = Array.from(messagesEl.children);
  children.forEach(function(c) {
    if ((c as HTMLElement).id !== "empty-state") messagesEl.removeChild(c);
  });
  currentStreamBubble = null;
  streamedContent = "";
  clearTraceEntries();

  /* Reconnect and reload conversation, then auto-send the message for replay */
  connectWebSocket(agentId, convId, messageText);
}

/* ---- Trace panel ---- */
function toggleTracePanel() {
  tracePanelOpen = !tracePanelOpen;
  if (tracePanelOpen) {
    tracePanel.classList.remove("hidden");
    traceToggleBtn.classList.add("text-coral");
    traceToggleBtn.classList.remove("text-muted");
  } else {
    tracePanel.classList.add("hidden");
    traceToggleBtn.classList.remove("text-coral");
    traceToggleBtn.classList.add("text-muted");
  }
}

interface TraceFinishData {
  usage: { prompt_tokens?: number; completion_tokens?: number } | null;
  model?: string;
  finish_reason?: string;
  latency_ms?: number;
}

function addTraceEntry(data: TraceFinishData, contentPreview: string) {
  traceCounter++;
  const promptTok = data.usage?.prompt_tokens || 0;
  const completionTok = data.usage?.completion_tokens || 0;
  const cost = calcCost(data.model, promptTok, completionTok);

  const entry: TraceEntry = {
    id: traceCounter,
    timestamp: Date.now(),
    usage: data.usage,
    contentPreview: contentPreview.slice(0, 120) + (contentPreview.length > 120 ? "..." : ""),
    model: data.model,
    finish_reason: data.finish_reason,
    latency_ms: data.latency_ms,
    tool_calls: [...pendingToolCalls],
    reasoning: pendingReasoning || undefined,
    cost: cost,
  };
  traceData.push(entry);
  pendingToolCalls = [];
  pendingReasoning = "";

  /* Update cumulative totals */
  cumulativePromptTokens += promptTok;
  cumulativeCompletionTokens += completionTok;
  cumulativeCost += cost;
  updateCumulativeSummary();

  traceEmpty.classList.add("hidden");
  renderTraceEntry(entry);

  /* Build a context state snapshot from accumulated trace data */
  buildContextSnapshotFromTrace(entry);
}

